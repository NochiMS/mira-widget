<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a0a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🌸  Mira Widget" android:textColor="#e8c87a"
            android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="28dp"/>

        <!-- EMOJİ SEÇİMİ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="EMOJİ" android:textColor="#888888"
            android:textSize="12sp" android:layout_marginBottom="10dp"/>

        <RadioGroup android:id="@+id/rg_emoji_mode"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="12dp">

            <RadioButton android:id="@+id/rb_emoji_auto"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Otomatik (yaşa göre değişir)"
                android:textColor="#f0ebe0" android:textSize="15sp"
                android:checked="true" android:paddingTop="8dp" android:paddingBottom="4dp"/>

            <RadioButton android:id="@+id/rb_emoji_custom"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Özel seçim (aşağıdan seç):"
                android:textColor="#aaaaaa" android:textSize="15sp"
                android:paddingTop="4dp" android:paddingBottom="8dp"/>

        </RadioGroup>

        <!-- Emoji grid — aktivite tarafından dinamik doldurulur -->
        <LinearLayout android:id="@+id/emoji_grid_container"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="28dp"/>

        <!-- YAZI BOYUTU -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="YAZI BOYUTU" android:textColor="#888888"
            android:textSize="12sp" android:layout_marginBottom="10dp"/>

        <RadioGroup android:id="@+id/rg_font"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="28dp">

            <RadioButton android:id="@+id/rb_xsmall" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="En Küçük" android:textColor="#888888" android:textSize="11sp"
                android:paddingTop="8dp" android:paddingBottom="8dp"/>
            <RadioButton android:id="@+id/rb_small" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Küçük" android:textColor="#c0bab0" android:textSize="13sp"
                android:paddingTop="8dp" android:paddingBottom="8dp"/>
            <RadioButton android:id="@+id/rb_medium" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Orta" android:textColor="#f0ebe0" android:textSize="16sp"
                android:checked="true" android:paddingTop="8dp" android:paddingBottom="8dp"/>
            <RadioButton android:id="@+id/rb_large" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Büyük" android:textColor="#f0ebe0" android:textSize="20sp"
                android:paddingTop="8dp" android:paddingBottom="8dp"/>
            <RadioButton android:id="@+id/rb_large_xl" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Az Büyük" android:textColor="#f0ebe0" android:textSize="23sp"
                android:paddingTop="8dp" android:paddingBottom="8dp"/>
            <RadioButton android:id="@+id/rb_xlarge" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Çok Büyük" android:textColor="#f0ebe0" android:textSize="25sp"
                android:paddingTop="8dp" android:paddingBottom="8dp"/>
            <RadioButton android:id="@+id/rb_xxlarge" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Çok Çok Büyük" android:textColor="#f0ebe0" android:textSize="31sp"
                android:paddingTop="8dp" android:paddingBottom="8dp"/>

        </RadioGroup>

        <!-- MİRA İSMİ RENGİ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="MİRA İSMİ RENGİ" android:textColor="#888888"
            android:textSize="12sp" android:layout_marginBottom="10dp"/>

        <RadioGroup android:id="@+id/rg_name_color"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="28dp">

            <RadioButton android:id="@+id/rb_name_gold" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Altın" android:textColor="#E8C87A" android:textSize="17sp"
                android:checked="true" android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_white" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Beyaz" android:textColor="#FFFFFF" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_purple" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mor" android:textColor="#C47FFF" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_teal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Turkuaz" android:textColor="#00D4B8" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_blue" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mavi" android:textColor="#5BA8FF" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_darkgray" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Koyu Gri" android:textColor="#7A7A95" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_pink" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pembe" android:textColor="#FF90C0" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_orange" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Turuncu" android:textColor="#FFA060" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_mint" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Nane" android:textColor="#70FFD0" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_yellow" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Sarı" android:textColor="#FFEE55" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_red" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Kırmızı" android:textColor="#FF6B6B" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_cyan" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Cyan" android:textColor="#60E0FF" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_lime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lime" android:textColor="#AAFF60" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_peach" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Şeftali" android:textColor="#FFB07A" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_lavender" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lavanta" android:textColor="#D4AAFF" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_name_silver" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gümüş" android:textColor="#CCCCCC" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>

        </RadioGroup>

        <!-- YAŞ METNİ RENGİ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="YAŞ METNİ RENGİ" android:textColor="#888888"
            android:textSize="12sp" android:layout_marginBottom="10dp"/>

        <RadioGroup android:id="@+id/rg_age_color"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="28dp">

            <RadioButton android:id="@+id/rb_age_gold" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Altın" android:textColor="#E8C87A" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_white" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Beyaz" android:textColor="#FFFFFF" android:textSize="17sp"
                android:checked="true" android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_purple" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mor" android:textColor="#C47FFF" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_teal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Turkuaz" android:textColor="#00D4B8" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_blue" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mavi" android:textColor="#5BA8FF" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_darkgray" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Koyu Gri" android:textColor="#7A7A95" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_pink" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pembe" android:textColor="#FF90C0" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_orange" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Turuncu" android:textColor="#FFA060" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_mint" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Nane" android:textColor="#70FFD0" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_yellow" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Sarı" android:textColor="#FFEE55" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_red" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Kırmızı" android:textColor="#FF6B6B" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_cyan" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Cyan" android:textColor="#60E0FF" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_lime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lime" android:textColor="#AAFF60" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_peach" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Şeftali" android:textColor="#FFB07A" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_lavender" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lavanta" android:textColor="#D4AAFF" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_age_silver" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gümüş" android:textColor="#CCCCCC" android:textSize="17sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>

        </RadioGroup>

        <!-- EMOJİ KONUMU -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="EMOJİ KONUMU" android:textColor="#888888"
            android:textSize="12sp" android:layout_marginBottom="10dp"/>

        <RadioGroup android:id="@+id/rg_align"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="28dp">

            <RadioButton android:id="@+id/rb_align_left"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="[🌸] Sola dayalı"
                android:textColor="#f0ebe0" android:textSize="15sp"
                android:checked="true" android:paddingTop="8dp" android:paddingBottom="8dp"/>

            <RadioButton android:id="@+id/rb_align_right_cell"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="  [🌸] Sağa dayalı"
                android:textColor="#f0ebe0" android:textSize="15sp"
                android:paddingTop="8dp" android:paddingBottom="8dp"/>

            <RadioButton android:id="@+id/rb_align_center"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text=" [🌸]  Ortalı"
                android:textColor="#f0ebe0" android:textSize="15sp"
                android:paddingTop="8dp" android:paddingBottom="8dp"/>

            <RadioButton android:id="@+id/rb_align_double"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌸 Mira | 0y 0a 27g 🌸  (çift emoji)"
                android:textColor="#f0ebe0" android:textSize="15sp"
                android:paddingTop="8dp" android:paddingBottom="8dp"/>

        </RadioGroup>

        <!-- ARKA PLAN RENGİ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ARKA PLAN RENGİ" android:textColor="#888888"
            android:textSize="12sp" android:layout_marginBottom="10dp"/>

        <RadioGroup android:id="@+id/rg_background"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="36dp">

            <RadioButton android:id="@+id/rb_dark" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Koyu Mor (varsayılan)" android:textColor="#b0a8c8" android:textSize="15sp"
                android:checked="true" android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_black" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Siyah" android:textColor="#aaaaaa" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_navy" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lacivert" android:textColor="#5B7FCC" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_green" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Koyu Yeşil" android:textColor="#4CAF80" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_purple" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mor" android:textColor="#C47FFF" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_rose" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Koyu Pembe" android:textColor="#FF7FAA" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_teal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Koyu Turkuaz" android:textColor="#00D4B8" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_orange" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Koyu Turuncu" android:textColor="#FFA060" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_gray" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Koyu Gri" android:textColor="#888888" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_transparent" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Şeffaf" android:textColor="#666666" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_crimson" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Koyu Kırmızı" android:textColor="#CC4444" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_midnight" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gece Mavisi" android:textColor="#3333AA" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_forest" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Orman Yeşili" android:textColor="#2A6030" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_amber" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Kehribar" android:textColor="#AA6600" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>
            <RadioButton android:id="@+id/rb_bg_slate" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Arduvaz" android:textColor="#5555AA" android:textSize="15sp"
                android:paddingTop="7dp" android:paddingBottom="7dp"/>

        </RadioGroup>

        <Button android:id="@+id/btn_save"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Kaydet" android:textSize="16sp" android:textColor="#0a0618"/>

    </LinearLayout>
</ScrollView>
