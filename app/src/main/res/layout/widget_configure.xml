<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a0a2e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌸  Mira Widget"
            android:textColor="#e8c87a"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="28dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YAZI BOYUTU"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginBottom="10dp"/>

        <RadioGroup
            android:id="@+id/rg_font"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="28dp">

            <RadioButton
                android:id="@+id/rb_small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Küçük"
                android:textColor="#c0bab0"
                android:textSize="13sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

            <RadioButton
                android:id="@+id/rb_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Orta"
                android:textColor="#f0ebe0"
                android:textSize="16sp"
                android:checked="true"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

            <RadioButton
                android:id="@+id/rb_large"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Büyük"
                android:textColor="#f0ebe0"
                android:textSize="20sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

            <RadioButton
                android:id="@+id/rb_xlarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Çok Büyük"
                android:textColor="#f0ebe0"
                android:textSize="25sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

            <RadioButton
                android:id="@+id/rb_xxlarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Çok Çok Büyük"
                android:textColor="#f0ebe0"
                android:textSize="31sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ARKA PLAN"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginBottom="10dp"/>

        <RadioGroup
            android:id="@+id/rg_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="36dp">

            <RadioButton
                android:id="@+id/rb_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Koyu"
                android:textColor="#f0ebe0"
                android:textSize="16sp"
                android:checked="true"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

            <RadioButton
                android:id="@+id/rb_transparent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Şeffaf"
                android:textColor="#f0ebe0"
                android:textSize="16sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

        </RadioGroup>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Kaydet"
            android:textSize="16sp"
            android:textColor="#0a0618"/>

    </LinearLayout>
</ScrollView>
